{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "toolbox",
  "version": "0.4.0",
  "identifier": "com.toolbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "工具箱",
        "width": 960,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzODQ4REQ4OUM2N0FGRDUKUldUVnIyZWMySTJFbzlrWEZEWnZidzFwWjU3Rkx2eTBuNEVoV3NNTEIrSXR6NFNtRERLa3RLck8K",
      "endpoints": [
        "https://dl.yzre.cn/toolbox/latest.json",
        "https://github.com/yunfengnobug/toolbox/releases/latest/download/latest.json"
      ]
    }
  }
}
